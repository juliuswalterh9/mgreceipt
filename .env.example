PORT=80
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
# MySQL 8 caching_sha2_password 시 "Public Key Retrieval is not allowed" 방지
DATABASE_URL="mysql://user:password@localhost:3306/receipt_db?allowPublicKeyRetrieval=true"
CORS_ORIGIN=http://localhost:5173
SEED_ADMIN_USER_ID=admin
SEED_ADMIN_PASSWORD=Admin1234!
SEED_ADMIN_NAME=시스템관리자
SEED_ADMIN_DEPARTMENT=IT 전략팀
SEED_USER_USER_ID=user01
SEED_USER_PASSWORD=1
SEED_USER_NAME=일반사용자
SEED_USER_DEPARTMENT=일반

# 네이버 클라우드 CLOVA Document OCR — 영수증 전용 (Secret·Invoke URL은 콘솔에서 동일 API 기준으로 복사)
CLOVA_OCR_SECRET=
CLOVA_OCR_RECEIPT_URL=https://xxxx.apigw.ntruss.com/custom/v1/{DomainId}/{InvokeKey}/document/receipt
# CLOVA_OCR_TIMEOUT_MS=90000
# CLOVA_OCR_DEBUG_SAVE=true
CLOVA_OCR_DEBUG_LOG=true
CLOVA_OCR_RECEIPT_ONLY=true
FORCE_CLOVA_OCR=true

# Ollama OCR (Tesseract 텍스트를 LLM으로 구조화)
# CLOVA 성공 후에도 USE_OLLAMA=true 이면 CLOVA 텍스트로 사용처(상호) LLM 보정 (CLOVA_OCR_LLM_REFINE=false 로 끔)
USE_OLLAMA_RECEIPT_OCR=false
# CLOVA_OCR_LLM_REFINE=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_OCR_MODEL=llama3.1:latest
# OLLAMA_TIMEOUT_MS=120000
